# OpenAI Configuration
NEXT_PUBLIC_OPENAI_API_KEY=sk-your-openai-api-key-here

# Coinbase Wallet Configuration
NEXT_PUBLIC_COINBASE_APP_NAME=SudoPath
NEXT_PUBLIC_COINBASE_APP_LOGO_URL=/logo.png
NEXT_PUBLIC_COINBASE_DARK_MODE=false

# Base Network Configuration
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_BASE_BLOCK_EXPLORER=https://basescan.org

# Farcaster Configuration
NEXT_PUBLIC_FARCASTER_HUB_URL=https://hub.snapshot.org/graphql
# FARCASTER_API_KEY=your-farcaster-api-key-here (optional)

# Application Configuration
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_NAME=SudoPath

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# Error Reporting (optional)
# SENTRY_DSN=your-sentry-dsn-here

